modules = ["nodejs-20", "go-1.21", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "PORT=5000 artifacts/toto-macau/toto-server"]
build = ["sh", "-c", "cd artifacts/toto-macau && go build -o toto-server ."]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Toto Macau"

[[workflows.workflow]]
name = "Toto Macau"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/toto-macau && PORT=5000 go run ."
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 23007
externalPort = 3000

[nix]
channel = "stable-25_05"
